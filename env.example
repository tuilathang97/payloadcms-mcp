# PayloadCMS MCP Server Configuration

# PayloadCMS Instance Configuration
PAYLOAD_HOST=http://localhost:3000
PAYLOAD_USERNAME=admin@example.com
PAYLOAD_PASSWORD=your-secure-password

# Alternative: Use API Key instead of username/password
# PAYLOAD_API_KEY=your-api-key-here

# Optional: PayloadCMS Collection Endpoint Override
# PAYLOAD_API_ENDPOINT=/api

# Optional: Default locale for content generation
# DEFAULT_LOCALE=en

# Optional: Content generation settings
# MAX_CONTENT_VARIATIONS=5
# DEFAULT_DEPENDENCY_DEPTH=3

# Optional: Debugging
# DEBUG=true
# LOG_LEVEL=info 