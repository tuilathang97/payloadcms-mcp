# PayloadCMS MCP Server Configuration

# PayloadCMS Instance Configuration
PAYLOAD_HOST=http://localhost:3000
PAYLOAD_USERNAME=admin@example.com
PAYLOAD_PASSWORD=your-secure-password

# Alternative: Use API Key instead of username/password
# PAYLOAD_API_KEY=your-api-key-here

# Optional: PayloadCMS Collection Endpoint Override
# PAYLOAD_API_ENDPOINT=/api

# PostgreSQL Configuration for Context Caching
# Required for enhanced context management and performance optimization
POSTGRES_URL=postgresql://username:password@localhost:5432/payloadcms_mcp
# Alternative environment variable name (either works)
# DATABASE_URL=postgresql://username:password@localhost:5432/payloadcms_mcp

# OpenAI Configuration for Semantic Search (Optional)
# Required for intelligent context discovery and similarity matching
# If not provided, basic text matching will be used instead
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Default locale for content generation
# DEFAULT_LOCALE=en

# Optional: Content generation settings
# MAX_CONTENT_VARIATIONS=5
# DEFAULT_DEPENDENCY_DEPTH=3

# Optional: Context store settings
# CONTEXT_CACHE_TTL=86400  # 24 hours in seconds
# CONTEXT_CLEANUP_INTERVAL=3600  # 1 hour in seconds

# Optional: Debugging
# DEBUG=true
# LOG_LEVEL=info 